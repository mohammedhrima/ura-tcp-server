F_OK int = 0
X_OK int = 1
W_OK int = 2
R_OK int = 4
SEEK_SET int = 0
SEEK_CUR int = 1
SEEK_END int = 2
STDIN_FILENO int = 0
STDOUT_FILENO int = 1
STDERR_FILENO int = 2
fn log(msg chars) void:
   write(1, msg, strlen(msg))
   return

fn get_time() chars:
   buf chars = heap[char](16)
   t long = time(0 as chars)
   tm chars = localtime(t)
   strftime(buf, 16 as long, "%H:%M:%S", tm)
   return buf

fn log_ts(color chars, tag chars, msg chars) void:
   tbuf chars = get_time()
   log("[0;90m[")
   log(tbuf)
   log("][0m ")
   log(color)
   log(tag)
   log("[0m ")
   log(msg)
   log("\n")
   free(tbuf)
   return

fn log_ts_right(color chars, tag chars, msg chars) void:
   tbuf chars = get_time()
   log("                    [0;90m[")
   log(tbuf)
   log("][0m ")
   log(color)
   log(tag)
   log("[0m ")
   log(msg)
   log("\n")
   free(tbuf)
   return

struct SockAddr:
   data chars

fn SockAddr_init(ref self SockAddr) void:
   self.data = heap[char](16)
   self.data[0] = 16 as char
   self.data[1] = 2 as char
   return

fn SockAddr_set_port(ref self SockAddr, port int) void:
   self.data[2] = (port >> 8) as char
   self.data[3] = (port & 255) as char
   return

fn SockAddr_set_ip(ref self SockAddr, a int, b int, c int, d int) void:
   self.data[4] = a as char
   self.data[5] = b as char
   self.data[6] = c as char
   self.data[7] = d as char
   return

fn SockAddr_delete(ref self SockAddr) void:
   free(self.data)
   return

fn banner() void:
   log("[0;36m")
   log("  ██████╗██╗     ██╗███████╗███╗   ██╗████████╗\n")
   log(" ██╔════╝██║     ██║██╔════╝████╗  ██║╚══██╔══╝\n")
   log(" ██║     ██║     ██║█████╗  ██╔██╗ ██║   ██║   \n")
   log(" ██║     ██║     ██║██╔══╝  ██║╚██╗██║   ██║   \n")
   log(" ╚██████╗███████╗██║███████╗██║ ╚████║   ██║   \n")
   log("  ╚═════╝╚══════╝╚═╝╚══════╝╚═╝  ╚═══╝   ╚═╝   \n")
   log("[0m")
   log("[0;90m─────────────────────────────────────────────[0m\n")
   log("[0;36m  URA Chat Client  [0;90m│[0m connecting to [0;33m127.0.0.1:17000[0m\n")
   log("[0;90m─────────────────────────────────────────────[0m\n\n")
   return

struct Client:
   fd int
   buf chars
   rbuf chars

fn Client_init(ref self Client) void:
   self.fd = socket(2, 1, 0)
   if self.fd < 0:
      log("failed to create client socket\n")
      exit(1)
   self.buf = heap[char](1024)
   self.rbuf = heap[char](1024)
   return

fn Client_delete(ref self Client) void:
   close(self.fd)
   free(self.buf)
   free(self.rbuf)
   return

fn main() int:
   banner()
   addr SockAddr
   SockAddr_set_port(ref addr, 17000)
   SockAddr_set_ip(ref addr, 127, 0, 0, 1)
   cli Client
   if connect(cli.fd, addr.data, 16) < 0:
      log_ts("[0;31m", "[client]", "connect failed")
      return 1
   log_ts("[0;36m", "[client]", "connected to server")
   r int = 0
   pid int = fork()
   if pid == 0:
      while True:
         r = read(cli.fd, cli.rbuf, 1023)
         if r <= 0:
            log_ts("[0;31m", "[client]", "server disconnected")
            break
         cli.rbuf[r] = 0 as char
         log("\r[2K")
         log_ts("[0;33m", "[server]", cli.rbuf)
         log("[0;36m[client][0m > ")
      return 0
   log("[0;36m[client][0m > ")
   while True:
      r = read(0, cli.buf, 1023)
      if r <= 0:
         break
      cli.buf[r - 1] = 0 as char
      write(cli.fd, cli.buf, r - 1)
      if strcmp(cli.buf, "/exit") == 0:
         break
      log("[0;36m[client][0m > ")
   SockAddr_delete(ref addr)
   Client_delete(ref cli)
   return 0

