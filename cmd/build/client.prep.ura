   tm_isdst int
   tm_gmtoff long
   tm_zone chars

proto fn time(timer chars) long
proto fn difftime(time1 long, time0 long) float
proto fn clock() long
proto fn gmtime(ref timer long) chars
proto fn localtime(ref timer long) chars
proto fn mktime(timeptr chars) long
