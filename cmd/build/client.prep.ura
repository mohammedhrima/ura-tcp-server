proto fn asctime(timeptr chars) chars
proto fn ctime(timer chars) chars
proto fn asctime_r(timeptr chars, buf chars) chars
proto fn ctime_r(timer chars, buf chars) chars
proto fn clock_gettime(clk_id int, tp chars) int
proto fn clock_settime(clk_id int, tp chars) int
proto fn nanosleep(req chars, rem chars) int
proto fn gettimeofday(tv chars, tz chars) int
proto fn getpid() int
proto fn getppid() int
proto fn getuid() int
proto fn geteuid() int
proto fn getgid() int
proto fn getegid() int
proto fn setuid(uid int) int
proto fn setgid(gid int) int
proto fn fork() int
proto fn execv(path chars, argv chars) int
proto fn execve(path chars, argv chars, envp chars) int
proto fn execvp(file chars, argv chars) int
proto fn _exit(code int) void
proto fn getcwd(buf chars, size long) chars
proto fn chdir(path chars) int
proto fn fchdir(fd int) int
proto fn access(path chars, mode int) int
proto fn unlink(path chars) int
proto fn rmdir(path chars) int
proto fn link(oldpath chars, newpath chars) int
proto fn symlink(target chars, linkpath chars) int
proto fn readlink(path chars, buf chars, bufsize long) long
proto fn rename(oldpath chars, newpath chars) int
