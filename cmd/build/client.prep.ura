fn strjoin(left chars, right chars) chars:
   len1 int = 0
   len2 int = 0
   if left != null:
      len1 = strlen(left)
   if right != null:
      len2 = strlen(right)
   str chars = calloc(((len1 + len2) + 1) as long, 1 as long)
   i int = 0
   while i < len1:
      str[i] = left[i]
      i += 1
   j int = 0
   while j < len2:
      str[i + j] = right[j]
      j += 1
   return str

struct String:
   value chars
   count int
   size int

fn String_delete(ref self String) void:
   free(self.value)
   return

fn String_assign(ref self String, str chars) void:
   if str == null:
      str = ""
   len int = strlen(str)
   if (self.value == null) or (self.size <= len):
      if self.size == 0:
         self.size = 10
      while self.size <= len:
         self.size *= 2
      self.value = realloc(self.value, self.size)
   strcpy(self.value, str)
   bzero(self.value + len, (self.size - len) as long)
   self.count = len
   return

fn String_join(ref self String, str chars) void:
   if str == null:
      return
   res chars = strjoin(self.value, str)
   String_assign(ref self, res)
   free(res)
   return

fn String_clear(ref self String) void:
   bzero(self.value, self.size as long)
   self.count = 0
   return

fn String_push(ref self String, c char) void:
   if (self.count + 1) >= self.size:
      if self.size == 0:
         self.size = 10
      else:
         self.size *= 2
      self.value = realloc(self.value, self.size)
   self.value[self.count] = c
   self.count += 1
   self.value[self.count] = 0 as char
   return

fn String_pop(ref self String) char:
   if self.count == 0:
      return 0 as char
   self.count -= 1
   c char = self.value[self.count]
   self.value[self.count] = 0 as char
   return c

fn String_new() String:
   s String
   s.size = 10
   s.value = calloc(10 as long, 1 as long)
   return s

fn String_from(str chars) String:
   s String = String_new()
   String_assign(ref s, str)
   return s

fn String_from_int(n int) String:
   s String = String_new()
   if n == 0:
      String_push(ref s, '0')
      return s
   neg bool = False
   num int = n
   if num < 0:
      neg = True
      num = 0 - num
   buf array[char] = stack[char](20)
   i int = 0
   while num > 0:
      buf[i] = ((num % 10) + 48) as char
      num = num / 10
      i += 1
   if neg:
      String_push(ref s, '-')
   j int = i - 1
   while j >= 0:
      String_push(ref s, buf[j])
      j -= 1
   return s

fn String_len(ref self String) int:
   return self.count

fn String_empty(ref self String) bool:
   return self.count == 0

fn String_c_str(ref self String) chars:
   return self.value

fn String_at(ref self String, i int) char:
   if (i < 0) or (i >= self.count):
      return 0 as char
   return self.value[i]

fn String_find(ref self String, needle chars) int:
   if needle == null:
      return 1 * -1
   i int = 0
   nlen int = strlen(needle)
   if nlen == 0:
      return 0
   while i <= (self.count - nlen):
      if strncmp(self.value + i, needle, nlen) == 0:
         return i
      i += 1
   return 1 * -1

fn String_contains(ref self String, needle chars) bool:
   return String_find(ref self, needle) != (1 * -1)

fn String_starts_with(ref self String, prefix chars) bool:
   if prefix == null:
      return True
   plen int = strlen(prefix)
   if plen > self.count:
      return False
   return strncmp(self.value, prefix, plen) == 0

fn String_ends_with(ref self String, suffix chars) bool:
   if suffix == null:
      return True
   slen int = strlen(suffix)
   if slen > self.count:
      return False
   offset int = self.count - slen
   return strncmp(self.value + offset, suffix, slen) == 0

fn String_substr(ref self String, start int, length int) String:
   res String = String_new()
   if (start < 0) or (start >= self.count):
      return res
   end int = start + length
   if end > self.count:
      end = self.count
   i int = start
   while i < end:
      String_push(ref res, self.value[i])
      i += 1
   return res

fn String_upper(ref self String) String:
   res String = String_new()
   i int = 0
   while i < self.count:
      c char = self.value[i]
      if (c >= 'a') and (c <= 'z'):
         v int = c as int - 32
         String_push(ref res, v as char)
      else:
         String_push(ref res, c)
      i += 1
   return res

fn String_lower(ref self String) String:
   res String = String_new()
   i int = 0
   while i < self.count:
      c char = self.value[i]
      if (c >= 'A') and (c <= 'Z'):
         v int = c as int + 32
         String_push(ref res, v as char)
      else:
         String_push(ref res, c)
      i += 1
   return res

fn String_trim(ref self String) String:
   start int = 0
   while start < self.count:
      c char = self.value[start]
      if (((c == ' ') or (c == '\t')) or (c == '\n')) or (c == '\r'):
         start += 1
      else:
         break
   end int = self.count
   while end > start:
      c char = self.value[end - 1]
      if (((c == ' ') or (c == '\t')) or (c == '\n')) or (c == '\r'):
         end -= 1
      else:
         break
   return String_substr(ref self, start, end - start)

fn String_replace(ref self String, old chars, replacement chars) String:
   res String = String_new()
   olen int = strlen(old)
   if olen == 0:
      String_assign(ref res, self.value)
      return res
   i int = 0
   while i < self.count:
      if (i <= (self.count - olen)) and (strncmp(self.value + i, old, olen) == 0):
         String_join(ref res, replacement)
         i += olen
      else:
         String_push(ref res, self.value[i])
         i += 1
   return res

fn String_repeat(ref self String, n int) String:
   res String = String_new()
   i int = 0
   while i < n:
      String_join(ref res, self.value)
      i += 1
   return res

fn String_reverse(ref self String) String:
   res String = String_new()
   i int = self.count - 1
   while i >= 0:
      String_push(ref res, self.value[i])
      i -= 1
   return res

fn String_compare(ref self String, ref other String) int:
